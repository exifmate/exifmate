{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "os:default",
    "store:default",
    "clipboard-manager:allow-read-text",
    "core:window:default",
    "core:window:allow-start-dragging",
    "log:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exiftool",
          "cmd": "$RESOURCE/resources/exiftool/exiftool",
          "args": true
        },
        {
          "name": "perl-version",
          "cmd": "perl",
          "args": ["-e", "print \"$^V\n\""]
        }
      ]
    }
  ]
}
